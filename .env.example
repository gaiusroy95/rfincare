# Server-side only. Copy to .env in this folder.
# Never prefix these with VITE_ — that would bundle them into the browser.

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

API_PORT=8080
# Local dev origin. On Vercel, VERCEL_URL is added automatically; optional extra origins:
# API_CORS_ORIGIN=https://rfincare-frontend.vercel.app
API_CORS_ORIGIN=http://127.0.0.1:4028
API_CORS_ALLOW_VERCEL=true
# Set true when frontend and API are on different domains (Vercel + Render).
API_COOKIE_CROSS_SITE=true
API_COOKIE_SECURE=false

# Developer panel at /development (password-protected). Set to false in production.
ENABLE_DEV_PANEL=true

UPLOAD_DIR=./uploads

# Admin password-reset OTP — three verifier emails (also configurable in Admin → Settings by super admin)
# ADMIN_VERIFIER_EMAIL_1=
# ADMIN_VERIFIER_EMAIL_2=
# ADMIN_VERIFIER_EMAIL_3=

# When API runs without the frontend folder (e.g. Render), frontend .env is stored here.
# FRONTEND_ENV_PATH=

# Optional: absolute path to built SPA (default: ../frontend/dist)
# FRONTEND_DIST=

# --- Optional integrations (scripts / future API routes only) ---
# SUPABASE_SERVICE_ROLE_KEY=   # e.g. backend/scripts/setup-demo-users.js (never ship to client)
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# PERPLEXITY_API_KEY=
# STRIPE_SECRET_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# MSG91 — SMS / OTP (India). Required when Admin → OTP settings uses MSG91.
# MSG91_AUTH_KEY=your_auth_key_from_msg91_dashboard
# MSG91_SENDER_ID=RFINCR
# MSG91_OTP_TEMPLATE_ID=your_dlt_otp_template_id
# MSG91_TEMPLATE_ID=          # alias for MSG91_OTP_TEMPLATE_ID
# MSG91_FLOW_TEMPLATE_ID=     # optional Flow API template
# MSG91_WHATSAPP_TEMPLATE_ID=       # template name (not SMS/email template ID)
# MSG91_WHATSAPP_NAMESPACE=         # from MSG91 → WhatsApp → Templates
# MSG91_WHATSAPP_INTEGRATED_NUMBER= # onboarded number with country code, e.g. 917300069952
# MSG91_WHATSAPP_LANGUAGE=en
# MSG91_WHATSAPP_INCLUDE_BUTTON=true  # set for Meta authentication (OTP) templates
# MSG91_ROUTE=4
# MSG91_FETCH_TIMEOUT_MS=15000
# MSG91 Email OTP (verified domain — recommended instead of Gmail SMTP on Render)
# MSG91_EMAIL_DOMAIN=mail.rfincare.com
# MSG91_EMAIL_FROM_EMAIL=no-reply@mail.rfincare.com
# MSG91_EMAIL_FROM_NAME=Rfincare
# MSG91_EMAIL_OTP_TEMPLATE_ID=otp_vari
# MSG91_EMAIL_OTP_VARIABLE=OTP_CODE
# OTP_CHANNEL_TIMEOUT_MS=20000
# MYSQL_CONNECT_TIMEOUT_MS=15000
LOG_OTP=true

# Staff welcome / transactional email (optional — logs to console if unset)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_PASSWORD=            # alias for SMTP_PASS (either name works)
# SMTP_FROM must match SMTP_USER for Gmail (or be a verified alias).
# Render and some hosts block outbound SMTP — use a transactional email API or rely on mobile OTP fallback.
# SMTP_CONNECTION_TIMEOUT_MS=10000
# SMTP_GREETING_TIMEOUT_MS=10000
# SMTP_SOCKET_TIMEOUT_MS=15000
# Public SPA URL for links in emails
APP_PUBLIC_URL=http://127.0.0.1:4028

# Local dev. On Vercel set to your site URL, e.g. https://rfincare-frontend.vercel.app
API_PUBLIC_URL=http://127.0.0.1:8080
# Comma-separated SPA callback URLs (user returns to the site that started OAuth)
# OAUTH_FRONTEND_CALLBACK=http://127.0.0.1:4028/oauth/callback
# OAUTH_FRONTEND_CALLBACK=https://rfincare.com/oauth/callback,https://www.rfincare.com/oauth/callback,https://rfincare-frontend.vercel.app/oauth/callback
OAUTH_FRONTEND_CALLBACK=http://127.0.0.1:4028/oauth/callback

# Google Cloud Console — redirect URI: {API_PUBLIC_URL}/auth/oauth/google/callback
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
# Azure App Registration (Accounts in any org + personal Microsoft) — redirect: .../auth/oauth/microsoft/callback
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
# Apple Developer — Services ID — redirect: .../auth/oauth/apple/callback (POST)
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_CLIENT_SECRET=

# --- UI auto-translation (web + mobile language switcher) ---
# Recommended for production. Get a key: https://console.cloud.google.com/apis/credentials
# 1) Create or select a Google Cloud project
# 2) Enable "Cloud Translation API": https://console.cloud.google.com/apis/library/translate.googleapis.com
# 3) Link a billing account (required even for the free tier — you are not charged until you exceed it)
# 4) APIs & Services → Credentials → Create credentials → API key
# 5) Restrict the key → API restrictions → "Cloud Translation API" only
# 6) Paste the key below and restart the backend
#
# Pricing (2026): first 500,000 characters/month FREE, then ~$20 per million characters.
# See: https://cloud.google.com/translate/pricing
# Our app caches every translated string in the database, so repeat visits cost almost nothing.
GOOGLE_TRANSLATE_API_KEY=
# When GOOGLE_TRANSLATE_API_KEY is set, the unofficial free "gtx" fallback is NOT used.
# Set true only if you want NO translation when the key above is missing:
# DISABLE_FREE_TRANSLATE=true
