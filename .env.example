# Server-side only. Copy to .env in this folder.
# Never prefix these with VITE_ — that would bundle them into the browser.

# --- PostgreSQL (Neon, local docker compose, or any Postgres host) ---
DATABASE_URL=postgresql://rfincare:rfincare@127.0.0.1:5432/rfincare
# DATABASE_SSL=false
# DATABASE_POOL_SIZE=10
# Neon / remote Postgres: cold starts can take 30–60s — raise timeout if migrate fails with "Authentication timed out"
# DATABASE_CONNECT_TIMEOUT_MS=60000
# DATABASE_CONNECT_RETRIES=3

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

API_PORT=8080
# Local dev origin. On Vercel, VERCEL_URL is added automatically; optional extra origins:
# API_CORS_ORIGIN=https://rfincare-frontend.vercel.app
API_CORS_ORIGIN=http://127.0.0.1:4028
API_CORS_ALLOW_VERCEL=true
# Set true when frontend and API are on different domains (Vercel + Render).
API_COOKIE_CROSS_SITE=true
API_COOKIE_SECURE=false

# Developer panel at /development (password-protected). Set to false in production.
ENABLE_DEV_PANEL=true

UPLOAD_DIR=./uploads

# --- Object storage (documents, logos, learning files) ---
# local = disk under UPLOAD_DIR (default for laptop dev)
# s3    = S3-compatible API (Supabase Storage, AWS S3, Cloudflare R2, MinIO)
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=s3
# S3_BUCKET=rfincare-uploads
# S3_REGION=ap-south-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# Supabase Storage S3 endpoint example:
# S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
# S3_FORCE_PATH_STYLE=true
# S3_PUBLIC_URL=
# S3_SIGNED_URL_TTL_SECONDS=3600
# UPLOAD_MAX_BYTES=26214400

# Admin password-reset OTP — three verifier emails (also configurable in Admin → Settings by super admin)
# ADMIN_VERIFIER_EMAIL_1=
# ADMIN_VERIFIER_EMAIL_2=
# ADMIN_VERIFIER_EMAIL_3=

# When API runs without the frontend folder (e.g. Render), frontend .env is stored here.
# FRONTEND_ENV_PATH=

# Optional: absolute path to built SPA (default: ../frontend/dist)
# FRONTEND_DIST=

# --- Optional integrations (scripts / future API routes only) ---
# SUPABASE_SERVICE_ROLE_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# PERPLEXITY_API_KEY=
# STRIPE_SECRET_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=RFINCR
# MSG91_OTP_TEMPLATE_ID=
# MSG91_TEMPLATE_ID=
# MSG91_FLOW_TEMPLATE_ID=
# MSG91_WHATSAPP_TEMPLATE_ID=
# MSG91_WHATSAPP_NAMESPACE=
# MSG91_WHATSAPP_INTEGRATED_NUMBER=
# MSG91_WHATSAPP_LANGUAGE=en
# MSG91_WHATSAPP_INCLUDE_BUTTON=true
# MSG91_ROUTE=4
# MSG91_FETCH_TIMEOUT_MS=15000
# MSG91_EMAIL_DOMAIN=mail.rfincare.com
# MSG91_EMAIL_FROM_EMAIL=no-reply@mail.rfincare.com
# MSG91_EMAIL_FROM_NAME=Rfincare
# MSG91_EMAIL_OTP_TEMPLATE_ID=otp_vari
# MSG91_EMAIL_OTP_VARIABLE=OTP_CODE
# OTP_CHANNEL_TIMEOUT_MS=20000
LOG_OTP=true

# Staff welcome / transactional email (optional — logs to console if unset)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_CONNECTION_TIMEOUT_MS=10000
# SMTP_GREETING_TIMEOUT_MS=10000
# SMTP_SOCKET_TIMEOUT_MS=15000
APP_PUBLIC_URL=http://127.0.0.1:4028

API_PUBLIC_URL=http://127.0.0.1:8080
# OAUTH_FRONTEND_CALLBACK=http://127.0.0.1:4028/oauth/callback
OAUTH_FRONTEND_CALLBACK=http://127.0.0.1:4028/oauth/callback

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_CLIENT_SECRET=

GOOGLE_TRANSLATE_API_KEY=
# DISABLE_FREE_TRANSLATE=true
