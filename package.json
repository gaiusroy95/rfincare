    "db:migrate:data:full": "node scripts/mysql-to-postgres-data.mjs --truncate",
    "db:patch:story-photo": "node scripts/run-sql-patch.mjs migrations/005_success_stories_photo.sql",
    "db:patch:collation": "node scripts/run-sql-patch.mjs migrations/006_collation_unicode_ci.sql",
    "db:patch:onboarding-collation": "node scripts/run-sql-patch.mjs migrations/029_staff_onboarding_collation.sql",
    "db:patch:leads-collation": "node scripts/run-sql-patch.mjs migrations/030_marketing_leads_collation.sql",
    "db:patch:milestone2": "node scripts/run-sql-patch.mjs migrations/007_milestone2_leads.sql",
